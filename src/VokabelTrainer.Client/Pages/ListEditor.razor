@page "/lists/new"
@page "/lists/{Id:int}/edit"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@inject ApiClient ApiClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudText Typo="Typo.h5" Class="mb-4">@(Id.HasValue ? "Liste bearbeiten" : "Neue Liste")</MudText>

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_name"
                          Label="Name"
                          Variant="Variant.Outlined"
                          Required="true" />

            <MudSelect T="int"
                       @bind-Value="_sourceLanguageId"
                       Label="Quellsprache"
                       Variant="Variant.Outlined"
                       Required="true">
                @foreach (var lang in _languages)
                {
                    <MudSelectItem T="int" Value="@lang.Id">@lang.DisplayName</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int"
                       @bind-Value="_targetLanguageId"
                       Label="Zielsprache"
                       Variant="Variant.Outlined"
                       Required="true">
                @foreach (var lang in _languages)
                {
                    <MudSelectItem T="int" Value="@lang.Id">@lang.DisplayName</MudSelectItem>
                }
            </MudSelect>

            <MudTextField @bind-Value="_rawVocabulary"
                          Label="Vokabeln"
                          Variant="Variant.Outlined"
                          Lines="10"
                          Placeholder="Eine Vokabel pro Zeile: Begriff = Uebersetzung1, Uebersetzung2" />

            <MudFileUpload T="IBrowserFile" Accept=".csv" FilesChanged="OnCsvFileSelected">
                <CustomContent Context="upload">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.UploadFile"
                               OnClick="@upload.OpenFilePickerAsync">
                        Import aus CSV
                    </MudButton>
                </CustomContent>
            </MudFileUpload>

            <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                <MudButton Variant="Variant.Outlined"
                           OnClick="@Cancel">
                    Abbrechen
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="@Save"
                           Disabled="@_saving">
                    Speichern
                </MudButton>
            </MudStack>
        </MudStack>
    }
</MudContainer>

@code {
    [Parameter]
    public int? Id { get; set; }

    private List<LanguageDto> _languages = [];
    private string _name = string.Empty;
    private int _sourceLanguageId;
    private int _targetLanguageId;
    private string _rawVocabulary = string.Empty;
    private bool _loading = true;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _languages = await ApiClient.GetLanguagesAsync();

        if (Id.HasValue)
        {
            var list = await ApiClient.GetListAsync(Id.Value);
            if (list is not null)
            {
                _name = list.Name;
                _sourceLanguageId = list.SourceLanguageId;
                _targetLanguageId = list.TargetLanguageId;
                _rawVocabulary = string.Join("\n", list.Entries.Select(e =>
                    $"{e.Term} = {string.Join(", ", e.Translations)}"));
            }
        }

        _loading = false;
    }

    private async Task Save()
    {
        _saving = true;
        try
        {
            if (Id.HasValue)
            {
                await ApiClient.UpdateListAsync(Id.Value, new UpdateVocabularyListRequest(_name, _sourceLanguageId, _targetLanguageId, _rawVocabulary));
            }
            else
            {
                await ApiClient.CreateListAsync(new CreateVocabularyListRequest(_name, _sourceLanguageId, _targetLanguageId, _rawVocabulary));
            }

            Snackbar.Add("Liste wurde gespeichert.", Severity.Success);
            NavigationManager.NavigateTo("/");
        }
        catch
        {
            Snackbar.Add("Liste konnte nicht gespeichert werden.", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task OnCsvFileSelected(IBrowserFile file)
    {
        try
        {
            using var stream = file.OpenReadStream();
            using var reader = new System.IO.StreamReader(stream);
            var content = await reader.ReadToEndAsync();
            var lines = content.Split('\n', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);

            if (lines.Length == 0) return;

            var startIndex = 0;

            // Check if first line is a header
            var firstLine = lines[0];
            if (!firstLine.Contains('=') && lines.Length > 1)
            {
                // Looks like a header row — try to use it for language hints and list name
                startIndex = 1;

                // Set list name from filename (without extension)
                if (string.IsNullOrWhiteSpace(_name))
                {
                    _name = System.IO.Path.GetFileNameWithoutExtension(file.Name);
                }

                // Try to match header columns to languages
                var headerParts = ParseCsvLine(firstLine);
                if (headerParts.Length >= 2)
                {
                    var sourceLang = _languages.FirstOrDefault(l =>
                        l.DisplayName.Equals(headerParts[0], StringComparison.OrdinalIgnoreCase) ||
                        l.Code.Equals(headerParts[0], StringComparison.OrdinalIgnoreCase));
                    var targetLang = _languages.FirstOrDefault(l =>
                        l.DisplayName.Equals(headerParts[1], StringComparison.OrdinalIgnoreCase) ||
                        l.Code.Equals(headerParts[1], StringComparison.OrdinalIgnoreCase));

                    if (sourceLang is not null) _sourceLanguageId = sourceLang.Id;
                    if (targetLang is not null) _targetLanguageId = targetLang.Id;
                }
            }

            // Parse data rows: CSV → "term = translation" format
            var vocabLines = new List<string>();
            for (var i = startIndex; i < lines.Length; i++)
            {
                var parts = ParseCsvLine(lines[i]);
                if (parts.Length >= 2)
                {
                    var term = parts[0].Trim();
                    var translation = parts[1].Trim();
                    if (term.Length > 0 && translation.Length > 0)
                    {
                        vocabLines.Add($"{term} = {translation}");
                    }
                }
            }

            if (vocabLines.Count > 0)
            {
                _rawVocabulary = string.IsNullOrWhiteSpace(_rawVocabulary)
                    ? string.Join("\n", vocabLines)
                    : _rawVocabulary + "\n" + string.Join("\n", vocabLines);

                Snackbar.Add($"{vocabLines.Count} Vokabeln aus CSV importiert.", Severity.Success);
            }
            else
            {
                Snackbar.Add("Keine Vokabeln in der CSV gefunden.", Severity.Warning);
            }
        }
        catch
        {
            Snackbar.Add("CSV konnte nicht gelesen werden.", Severity.Error);
        }
    }

    private static string[] ParseCsvLine(string line)
    {
        var result = new List<string>();
        var current = new System.Text.StringBuilder();
        var inQuotes = false;

        for (var i = 0; i < line.Length; i++)
        {
            var c = line[i];
            if (c == '"')
            {
                if (inQuotes && i + 1 < line.Length && line[i + 1] == '"')
                {
                    current.Append('"');
                    i++; // skip escaped quote
                }
                else
                {
                    inQuotes = !inQuotes;
                }
            }
            else if (c == ',' && !inQuotes)
            {
                result.Add(current.ToString());
                current.Clear();
            }
            else
            {
                current.Append(c);
            }
        }
        result.Add(current.ToString());

        return result.ToArray();
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/");
    }
}
