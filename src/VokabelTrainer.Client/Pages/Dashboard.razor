@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@inject ApiClient ApiClient
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudText Typo="Typo.h5">Meine Listen</MudText>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       OnClick="@(() => NavigationManager.NavigateTo("/lists/new"))">
                + Neue Liste
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="@(() => NavigationManager.NavigateTo("/training/start"))">
                Alle trainieren
            </MudButton>
        </MudStack>
    </MudStack>

    @if (_lists is null)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (_lists.Count == 0)
    {
        <MudAlert Severity="Severity.Info">Noch keine Listen vorhanden</MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var list in _lists)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard>
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@list.Name</MudText>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mt-2">
                                <LanguageFlag FlagSvg="@list.SourceFlagSvg" />
                                <MudText Typo="Typo.body2">@list.SourceLanguageName</MudText>
                                <MudText Typo="Typo.body2">→</MudText>
                                <LanguageFlag FlagSvg="@list.TargetFlagSvg" />
                                <MudText Typo="Typo.body2">@list.TargetLanguageName</MudText>
                            </MudStack>
                            <MudText Typo="Typo.body2" Class="mt-1">@list.VocabularyCount Vokabeln</MudText>
                            <div class="mt-2">
                                <BoxDistribution Distribution="@list.BoxDistribution" />
                            </div>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       OnClick="@(() => NavigationManager.NavigateTo($"/training/start/{list.Id}"))">
                                Trainieren
                            </MudButton>
                            <MudButton Variant="Variant.Text"
                                       OnClick="@(() => NavigationManager.NavigateTo($"/lists/{list.Id}/edit"))">
                                Bearbeiten
                            </MudButton>
                            <MudButton Variant="Variant.Text"
                                       OnClick="@(() => NavigationManager.NavigateTo($"/progress/{list.Id}"))">
                                Fortschritt
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private List<VocabularyListSummaryDto>? _lists;

    protected override async Task OnInitializedAsync()
    {
        _lists = await ApiClient.GetListsAsync();
    }
}
