@page "/training/{SessionId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@inject ApiClient ApiClient
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (_question is not null)
    {
        @if (_lastFeedback is not null)
        {
            @if (_lastFeedback.IsCorrect)
            {
                <MudAlert Severity="Severity.Success" Class="mb-3" Dense="true">
                    Richtig! <strong>@_lastTerm</strong>
                </MudAlert>
            }
            else
            {
                <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">
                    <strong>@_lastTerm</strong> — Richtig: @string.Join(", ", _lastFeedback.CorrectAnswers)
                    <MudText Typo="Typo.caption">Box @_lastFeedback.NewBox (falsch → Box wird zurueckgesetzt)</MudText>
                </MudAlert>
            }
        }

        <MudProgressLinear Value="@Progress" Max="100" Color="Color.Primary" Class="mb-2" />
        <MudText Typo="Typo.body2" Class="mb-2">Frage @_question.CurrentIndex von @_question.TotalCount</MudText>

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-3">
            <LanguageFlag FlagSvg="@_question.SourceFlagSvg" />
            <MudText Typo="Typo.body1">@_question.SourceLanguageName</MudText>
            <MudText Typo="Typo.body1">→</MudText>
            <LanguageFlag FlagSvg="@_question.TargetFlagSvg" />
            <MudText Typo="Typo.body1">@_question.TargetLanguageName</MudText>
        </MudStack>

        <MudPaper Elevation="2" Class="pa-6 mb-4 d-flex justify-center">
            <MudText Typo="Typo.h4">@_question.Prompt</MudText>
        </MudPaper>

        <MudTextField @bind-Value="_answer"
                      Label="Antwort"
                      Variant="Variant.Outlined"
                      AutoFocus="true"
                      OnKeyDown="OnKeyDown"
                      Disabled="_submitting"
                      Class="mb-4" />

        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SubmitAnswer"
                       Disabled="_submitting">
                Pruefen
            </MudButton>
            @if (_isEndlos)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Warning"
                           OnClick="AbortSession">
                    Abbrechen
                </MudButton>
            }
        </MudStack>
    }
</MudContainer>

@code {
    [Parameter] public int SessionId { get; set; }
    [SupplyParameterFromQuery(Name = "mode")] public string? Mode { get; set; }

    private bool _loading = true;
    private TrainingQuestionDto? _question;
    private SubmitAnswerResponse? _lastFeedback;
    private string? _lastTerm;
    private string _answer = string.Empty;
    private bool _submitting;
    private bool _isEndlos;

    private double Progress => _question is not null && _question.TotalCount > 0
        ? (double)_question.CurrentIndex / _question.TotalCount * 100
        : 0;

    protected override async Task OnInitializedAsync()
    {
        _isEndlos = string.Equals(Mode, "endlos", StringComparison.OrdinalIgnoreCase);
        await LoadNextQuestion();
    }

    private async Task LoadNextQuestion()
    {
        var question = await ApiClient.GetNextQuestionAsync(SessionId);
        if (question is null)
        {
            NavigationManager.NavigateTo($"/training/result/{SessionId}");
            return;
        }

        _question = question;
        _answer = string.Empty;
        _loading = false;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitAnswer();
        }
    }

    private async Task SubmitAnswer()
    {
        if (_question is null || _submitting) return;

        _submitting = true;
        try
        {
            var request = new SubmitAnswerRequest(SessionId, _question.VocabularyId, _question.Direction, _answer);
            var feedback = await ApiClient.SubmitAnswerAsync(request);

            if (feedback?.SessionComplete == true)
            {
                NavigationManager.NavigateTo($"/training/result/{SessionId}");
                return;
            }

            // Store feedback from this question, then immediately load next
            _lastFeedback = feedback;
            _lastTerm = _question.Prompt;
            await LoadNextQuestion();
        }
        finally
        {
            _submitting = false;
        }
    }

    private async Task AbortSession()
    {
        await ApiClient.AbortSessionAsync(SessionId);
        NavigationManager.NavigateTo($"/training/result/{SessionId}");
    }
}
