@page "/progress/{ListId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@inject ApiClient ApiClient
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    @if (_progress is null)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <MudStack Spacing="4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.h5">@_progress.ListName – Fortschritt</MudText>
                <MudButton Variant="Variant.Outlined" OnClick="@(() => NavigationManager.NavigateTo("/"))">Zurueck</MudButton>
            </MudStack>

            <LeitnerExplanation />

            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Verteilung nach Boxen</MudText>
                <MudChart T="double"
                          ChartType="ChartType.Bar"
                          ChartSeries="@_boxSeries"
                          ChartLabels="@_boxLabels"
                          Width="100%"
                          Height="300px" />
            </MudPaper>

            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Erfolgsrate pro Sitzung</MudText>
                @if (_progress.SessionHistory.Count == 0)
                {
                    <MudText Typo="Typo.body2">Noch keine Sitzungen vorhanden.</MudText>
                }
                else
                {
                    <MudChart T="double"
                              ChartType="ChartType.Line"
                              ChartSeries="@_sessionSeries"
                              ChartLabels="@_sessionLabels"
                              Width="100%"
                              Height="300px" />
                }
            </MudPaper>

            <MudText Typo="Typo.body1">Sitzungen gesamt: <strong>@_progress.TotalSessions</strong></MudText>

            @if (_progress.ProblemVocabulary.Count > 0)
            {
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.h6" GutterBottom="true">Problematische Vokabeln</MudText>
                    <MudSimpleTable>
                        <thead>
                            <tr>
                                <th>Begriff</th>
                                <th>Fehler</th>
                                <th>Aktuelle Box</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var vocab in _progress.ProblemVocabulary)
                            {
                                <tr>
                                    <td>@vocab.Term</td>
                                    <td>@vocab.TimesWrong-mal falsch</td>
                                    <td>Box @vocab.CurrentBox</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            }
        </MudStack>
    }
</MudContainer>

@code {
    [Parameter] public int ListId { get; set; }

    private ListProgressDto? _progress;

    private List<ChartSeries<double>> _boxSeries = new();
    private string[] _boxLabels = ["Box 1", "Box 2", "Box 3", "Box 4", "Box 5"];

    private List<ChartSeries<double>> _sessionSeries = new();
    private string[] _sessionLabels = [];

    protected override async Task OnInitializedAsync()
    {
        _progress = await ApiClient.GetListProgressAsync(ListId);

        if (_progress is not null)
        {
            _boxSeries =
            [
                new ChartSeries<double>
                {
                    Name = "Vokabeln",
                    Data = new ChartData<double>(new double[]
                    {
                        (double)_progress.BoxDistribution.Box1,
                        (double)_progress.BoxDistribution.Box2,
                        (double)_progress.BoxDistribution.Box3,
                        (double)_progress.BoxDistribution.Box4,
                        (double)_progress.BoxDistribution.Box5,
                    })
                }
            ];

            if (_progress.SessionHistory.Count > 0)
            {
                _sessionLabels = _progress.SessionHistory
                    .Select((s, i) => $"S{i + 1}")
                    .ToArray();

                _sessionSeries =
                [
                    new ChartSeries<double>
                    {
                        Name = "Erfolgsrate (%)",
                        Data = new ChartData<double>(_progress.SessionHistory
                            .Select(s => s.SuccessRate * 100)
                            .ToArray())
                    }
                ];
            }
        }
    }
}
