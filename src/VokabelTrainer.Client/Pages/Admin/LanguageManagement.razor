@page "/admin/languages"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]

@inject ApiClient ApiClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudText Typo="Typo.h5">Sprachenverwaltung</MudText>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="@OpenCreateDialog">
            + Sprache anlegen
        </MudButton>
    </MudStack>

    @if (_languages is null)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <MudTable Items="_languages" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>Code</MudTh>
                <MudTh>Name</MudTh>
                <MudTh>Flagge</MudTh>
                <MudTh>Aktionen</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Code">@context.Code</MudTd>
                <MudTd DataLabel="Name">@context.DisplayName</MudTd>
                <MudTd DataLabel="Flagge">
                    <LanguageFlag FlagSvg="@context.FlagSvg" />
                </MudTd>
                <MudTd DataLabel="Aktionen">
                    <MudTooltip Text="Bearbeiten">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       OnClick="@(() => OpenEditDialog(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Löschen">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       OnClick="@(() => HandleDeleteLanguage(context))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudContainer>

@if (_showDialog)
{
    <MudDialog @bind-Visible="_showDialog">
        <TitleContent>
            <MudText Typo="Typo.h6">@(_editingLanguage is null ? "Sprache anlegen" : "Sprache bearbeiten")</MudText>
        </TitleContent>
        <DialogContent>
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_formCode"
                              Label="Code"
                              Variant="Variant.Outlined"
                              Required="true" />
                <MudTextField @bind-Value="_formDisplayName"
                              Label="Name"
                              Variant="Variant.Outlined"
                              Required="true" />
                <MudTextField @bind-Value="_formFlagSvg"
                              Label="Flagge (SVG)"
                              Variant="Variant.Outlined"
                              Lines="5" />
                @if (!string.IsNullOrEmpty(_formFlagSvg))
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.body2">Vorschau:</MudText>
                        <LanguageFlag FlagSvg="@_formFlagSvg" />
                    </MudStack>
                }
            </MudStack>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@CloseDialog">Abbrechen</MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="@HandleSaveLanguage"
                       Disabled="@_isSaving">
                Speichern
            </MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    private List<LanguageDto>? _languages;
    private bool _showDialog;
    private LanguageDto? _editingLanguage;
    private string _formCode = string.Empty;
    private string _formDisplayName = string.Empty;
    private string _formFlagSvg = string.Empty;
    private bool _isSaving;

    protected override async Task OnInitializedAsync()
    {
        await LoadLanguages();
    }

    private async Task LoadLanguages()
    {
        _languages = await ApiClient.GetLanguagesAsync();
    }

    private void OpenCreateDialog()
    {
        _editingLanguage = null;
        _formCode = string.Empty;
        _formDisplayName = string.Empty;
        _formFlagSvg = string.Empty;
        _showDialog = true;
    }

    private void OpenEditDialog(LanguageDto language)
    {
        _editingLanguage = language;
        _formCode = language.Code;
        _formDisplayName = language.DisplayName;
        _formFlagSvg = language.FlagSvg ?? string.Empty;
        _showDialog = true;
    }

    private void CloseDialog()
    {
        _showDialog = false;
    }

    private async Task HandleSaveLanguage()
    {
        if (string.IsNullOrWhiteSpace(_formCode) || string.IsNullOrWhiteSpace(_formDisplayName))
        {
            Snackbar.Add("Code und Name sind Pflichtfelder.", Severity.Warning);
            return;
        }

        _isSaving = true;
        try
        {
            var flagSvg = string.IsNullOrWhiteSpace(_formFlagSvg) ? null : _formFlagSvg;

            if (_editingLanguage is null)
            {
                await ApiClient.CreateLanguageAsync(new CreateLanguageRequest(_formCode, _formDisplayName, flagSvg));
                Snackbar.Add("Sprache wurde angelegt.", Severity.Success);
            }
            else
            {
                await ApiClient.UpdateLanguageAsync(_editingLanguage.Id, new UpdateLanguageRequest(_formCode, _formDisplayName, flagSvg));
                Snackbar.Add("Sprache wurde aktualisiert.", Severity.Success);
            }

            _showDialog = false;
            await LoadLanguages();
        }
        catch
        {
            Snackbar.Add("Sprache konnte nicht gespeichert werden.", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task HandleDeleteLanguage(LanguageDto language)
    {
        var result = await DialogService.ShowMessageBoxAsync(
            "Sprache löschen",
            $"Soll die Sprache \"{language.DisplayName}\" wirklich gelöscht werden?",
            yesText: "Löschen",
            cancelText: "Abbrechen");

        if (result != true)
            return;

        try
        {
            await ApiClient.DeleteLanguageAsync(language.Id);
            Snackbar.Add($"Sprache \"{language.DisplayName}\" wurde gelöscht.", Severity.Success);
            await LoadLanguages();
        }
        catch
        {
            Snackbar.Add("Sprache konnte nicht gelöscht werden. Möglicherweise wird sie noch verwendet.", Severity.Error);
        }
    }
}
