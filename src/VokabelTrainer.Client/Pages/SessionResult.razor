@page "/training/result/{SessionId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@inject ApiClient ApiClient
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    @if (_result is null)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <MudText Typo="Typo.h2" Color="@ScoreColor" Align="Align.Center" Class="mb-2">
            @(_result.SuccessRate.ToString("0"))%
        </MudText>

        <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-4">
            @_result.CorrectAnswers von @_result.TotalQuestions richtig
        </MudText>

        @if (_result.WrongAnswers.Count > 0)
        {
            <MudText Typo="Typo.h6" Class="mb-2">Fehler</MudText>
            <MudSimpleTable Hover="true" Dense="true" Class="mb-4">
                <thead>
                    <tr>
                        <th>Begriff</th>
                        <th>Korrekte Antworten</th>
                        <th>Deine Antwort</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var wrong in _result.WrongAnswers)
                    {
                        <tr>
                            <td>@wrong.Term</td>
                            <td>@string.Join(", ", wrong.CorrectTranslations)</td>
                            <td>@wrong.GivenAnswer</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }

        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="@(() => NavigationManager.NavigateTo("/training/start"))">
                Nochmal trainieren
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       OnClick="@(() => NavigationManager.NavigateTo("/"))">
                Zurueck
            </MudButton>
        </MudStack>
    }
</MudContainer>

@code {
    [Parameter] public int SessionId { get; set; }

    private SessionResultDto? _result;

    private Color ScoreColor => _result?.SuccessRate switch
    {
        >= 80 => Color.Success,
        >= 50 => Color.Warning,
        _ => Color.Error
    };

    protected override async Task OnInitializedAsync()
    {
        _result = await ApiClient.GetSessionResultAsync(SessionId);
    }
}
