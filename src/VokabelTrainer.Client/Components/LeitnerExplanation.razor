        <MudChip T="string" Style="background-color: #ff9800; color: white;">Box 2</MudChip>
        <MudChip T="string" Style="background-color: #ffeb3b; color: black;">Box 3</MudChip>
        <MudChip T="string" Style="background-color: #8bc34a; color: white;">Box 4</MudChip>
        <MudChip T="string" Style="background-color: #4caf50; color: white;">Box 5 – Sitzt!</MudChip>
    </MudStack>
</MudPaper>
