<PageLayout IsAdmin="@IsAdmin">
    @if (Result is not null)
    {
        <h1 class="title">Ergebnis</h1>

        <div class="has-text-centered mb-5">
            <p class="score-display has-text-@GetColorClass()">
                @Result.SuccessRate%
            </p>
            <p class="is-size-4 mt-2">@Result.CorrectAnswers von @Result.TotalQuestions richtig</p>
            @if (Result.AverageResponseSeconds.HasValue)
            {
                <p class="is-size-6 has-text-grey mt-1">⌀ @Result.AverageResponseSeconds.Value s pro Antwort</p>
            }
        </div>

        @if (Result.WrongAnswers.Count > 0)
        {
            <h2 class="title is-5">Falsche Antworten</h2>
            <div class="table-container">
                <table class="table is-fullwidth is-striped">
                    <thead>
                        <tr>
                            <th>Begriff</th>
                            <th>Korrekte Antworten</th>
                            <th>Deine Antwort</th>
                            <th>Zeit</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var wrong in Result.WrongAnswers)
                        {
                            <tr>
                                <td>@wrong.Term</td>
                                <td>@string.Join(", ", wrong.CorrectTranslations)</td>
                                <td class="has-text-danger">@wrong.GivenAnswer</td>
                                <td>@(wrong.ResponseSeconds.HasValue ? $"{wrong.ResponseSeconds.Value:0.0}s" : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (Progress is not null)
        {
            <div class="box mt-5">
                <h2 class="subtitle">Aktueller Fortschritt — @Progress.ListName</h2>
                <BoxDistribution Distribution="@Progress.BoxDistribution" />
                <div class="columns mt-3 has-text-centered">
                    <div class="column"><span class="tag is-danger">Box 1: @Progress.BoxDistribution.Box1</span></div>
                    <div class="column"><span class="tag is-warning">Box 2: @Progress.BoxDistribution.Box2</span></div>
                    <div class="column"><span class="tag is-info">Box 3: @Progress.BoxDistribution.Box3</span></div>
                    <div class="column"><span class="tag is-primary">Box 4: @Progress.BoxDistribution.Box4</span></div>
                    <div class="column"><span class="tag is-success">Box 5: @Progress.BoxDistribution.Box5</span></div>
                </div>
                <p class="has-text-centered mt-2">@Progress.TotalSessions Sitzungen absolviert</p>
            </div>
        }

        <div class="field is-grouped mt-5">
            <div class="control">
                <a href="/training/start" class="button is-primary">Nochmal trainieren</a>
            </div>
            <div class="control">
                <a href="/" class="button is-light">Zurueck</a>
            </div>
        </div>
    }
    else
    {
        <div class="notification is-warning">Ergebnis nicht gefunden.</div>
        <a href="/" class="button is-light">Zurueck</a>
    }
</PageLayout>

@code {
    [Parameter] public SessionResultDto? Result { get; set; }
    [Parameter] public ListProgressDto? Progress { get; set; }
    [Parameter] public bool IsAdmin { get; set; }

    private string GetColorClass()
    {
        if (Result!.SuccessRate > 70) return "success";
        if (Result.SuccessRate > 40) return "warning";
        return "danger";
    }
}
