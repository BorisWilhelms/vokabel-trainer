@page "/training/{SessionId:int}"
@attribute [Authorize]
@inject TrainingService TrainingService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation

@if (_feedback is not null)
{
    <div class="notification @(_feedback.IsCorrect ? "is-success" : "is-danger") mb-4">
        @if (_feedback.IsCorrect)
        {
            <p><strong>Richtig!</strong> @_feedbackPrompt</p>
        }
        else
        {
            <p><strong>Falsch!</strong> @_feedbackPrompt &rarr; <strong>@string.Join(", ", _feedback.CorrectAnswers)</strong></p>
            <p class="is-size-7">Deine Antwort: @_submittedAnswer</p>
        }
    </div>
}

@if (_question is not null)
{
    <progress class="progress is-primary mb-4" value="@(_question.CurrentIndex - 1)" max="@_question.TotalCount"></progress>
    <p class="mb-2">Frage @_question.CurrentIndex von @_question.TotalCount</p>

    <div class="is-flex is-align-items-center mb-3">
        @if (_question.Direction == Direction.SourceToTarget)
        {
            <LanguageFlag FlagSvg="@_question.SourceFlagSvg" />
            <span class="ml-1 mr-2">@_question.SourceLanguageName</span>
            <span class="mr-2">&rarr;</span>
            <LanguageFlag FlagSvg="@_question.TargetFlagSvg" />
            <span class="ml-1">@_question.TargetLanguageName</span>
        }
        else
        {
            <LanguageFlag FlagSvg="@_question.TargetFlagSvg" />
            <span class="ml-1 mr-2">@_question.TargetLanguageName</span>
            <span class="mr-2">&rarr;</span>
            <LanguageFlag FlagSvg="@_question.SourceFlagSvg" />
            <span class="ml-1">@_question.SourceLanguageName</span>
        }
    </div>

    <div class="box has-text-centered mb-5">
        <p class="is-size-3">@_question.Prompt</p>
    </div>

    <form method="post" action="/training/@SessionId?mode=@Mode">
        <AntiforgeryToken />
        <input type="hidden" name="VocabularyId" value="@_question.VocabularyId" />
        <input type="hidden" name="QuestionDirection" value="@((int)_question.Direction)" />
        <input type="hidden" name="PreviousPrompt" value="@_question.Prompt" />

        <div class="field">
            <div class="control">
                <input class="input is-medium" type="text" name="Answer" placeholder="Antwort" autofocus />
            </div>
        </div>
        <div class="field is-grouped">
            <div class="control">
                <button type="submit" class="button is-primary">Pruefen</button>
            </div>
            @if (_isEndlos)
            {
                <div class="control">
                    <button type="submit" name="Action" value="abort" class="button is-warning is-outlined">Abbrechen</button>
                </div>
            }
        </div>
    </form>
}
else if (!_redirecting)
{
    <div class="notification is-warning">Keine Fragen verfuegbar.</div>
    <a href="/" class="button">Zurueck</a>
}

@code {
    [Parameter]
    public int SessionId { get; set; }

    [SupplyParameterFromQuery(Name = "mode")]
    public string? Mode { get; set; }

    private TrainingQuestionDto? _question;
    private SubmitAnswerResponse? _feedback;
    private string? _submittedAnswer;
    private string? _feedbackPrompt;
    private bool _isEndlos;
    private bool _redirecting;

    protected override async Task OnInitializedAsync()
    {
        _isEndlos = string.Equals(Mode, "Endlos", StringComparison.OrdinalIgnoreCase);

        var httpContext = HttpContextAccessor.HttpContext!;

        if (httpContext.Request.Method == "POST" && httpContext.Request.HasFormContentType)
        {
            var form = await httpContext.Request.ReadFormAsync();
            var action = form["Action"].FirstOrDefault();

            if (string.Equals(action, "abort", StringComparison.OrdinalIgnoreCase))
            {
                await TrainingService.AbortSessionAsync(SessionId);
                _redirecting = true;
                Navigation.NavigateTo($"/training/result/{SessionId}", forceLoad: true);
                return;
            }

            var answer = form["Answer"].FirstOrDefault() ?? "";
            var vocabIdStr = form["VocabularyId"].FirstOrDefault();
            var directionStr = form["QuestionDirection"].FirstOrDefault();
            var previousPrompt = form["PreviousPrompt"].FirstOrDefault();

            if (int.TryParse(vocabIdStr, out var vocabId) && int.TryParse(directionStr, out var dirInt))
            {
                var direction = (Direction)dirInt;
                _submittedAnswer = answer;
                _feedbackPrompt = previousPrompt;
                _feedback = await TrainingService.SubmitAnswerAsync(SessionId, vocabId, direction, answer);

                if (_feedback.SessionComplete)
                {
                    _redirecting = true;
                    Navigation.NavigateTo($"/training/result/{SessionId}", forceLoad: true);
                    return;
                }
            }
        }

        _question = await TrainingService.GetNextQuestionAsync(SessionId);
        if (_question is null)
        {
            _redirecting = true;
            Navigation.NavigateTo($"/training/result/{SessionId}", forceLoad: true);
        }
    }
}
