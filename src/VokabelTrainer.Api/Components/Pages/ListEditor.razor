<PageLayout IsAdmin="@IsAdmin">
    <h1 class="title">@(Id.HasValue ? "Liste bearbeiten" : "Neue Liste")</h1>

    <form method="post" action="@(Id.HasValue ? $"/lists/{Id}" : "/lists")">
        <div class="field">
            <label class="label" for="name-input">Name</label>
            <div class="control">
                <input id="name-input" class="input" type="text" name="Name" value="@Name" required />
            </div>
        </div>

        <div class="field">
            <label class="label">Ausgangssprache</label>
            <div class="control">
                <div class="select is-fullwidth">
                    <select name="SourceLanguageId" required>
                        <option value="">-- Sprache wählen --</option>
                        @if (Languages is not null)
                        {
                            @foreach (var lang in Languages)
                            {
                                <option value="@lang.Id" selected="@(lang.Id == SourceLanguageId)">@lang.DisplayName</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="field">
            <label class="label">Zielsprache</label>
            <div class="control">
                <div class="select is-fullwidth">
                    <select name="TargetLanguageId" required>
                        <option value="">-- Sprache wählen --</option>
                        @if (Languages is not null)
                        {
                            @foreach (var lang in Languages)
                            {
                                <option value="@lang.Id" selected="@(lang.Id == TargetLanguageId)">@lang.DisplayName</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="field">
            <label class="label">Importieren</label>
            <div class="control buttons">
                <label class="button is-light">
                    <span>CSV importieren</span>
                    <input type="file" accept=".csv" onchange="handleCsvImport(this)" style="display:none" />
                </label>
                @if (OcrEnabled)
                {
                    <label class="button is-primary is-light" id="ocr-btn">
                        <span>Foto(s) scannen</span>
                        <input type="file" accept="image/*" multiple onchange="handleOcrImport(this)" style="display:none" />
                    </label>
                }
            </div>
            <div id="ocr-status" class="help"></div>
        </div>

        <div class="field">
            <label class="label" for="vocabulary-textarea">Vokabeln</label>
            <div class="control">
                <textarea id="vocabulary-textarea" class="textarea" rows="10" name="RawVocabulary"
                          placeholder="Eine Vokabel pro Zeile: Begriff = Übersetzung1, Übersetzung2" required>@RawVocabulary</textarea>
            </div>
        </div>

        <div class="field is-grouped">
            <div class="control">
                <button type="submit" class="button is-primary">Speichern</button>
            </div>
            <div class="control">
                <a href="/" class="button is-light">Abbrechen</a>
            </div>
        </div>
    </form>

    <script>
    function handleCsvImport(input) {
        var file = input.files[0];
        if (!file) return;
        var reader = new FileReader();
        reader.onload = function(e) {
            var lines = e.target.result.split('\n');
            var textarea = document.getElementById('vocabulary-textarea');
            var nameInput = document.getElementById('name-input');
            var startIndex = 0;

            if (lines.length > 1 && !lines[0].includes('=')) {
                if (!nameInput.value) {
                    nameInput.value = file.name.replace(/\.csv$/i, '');
                    nameInput.dispatchEvent(new Event('change'));
                }
                startIndex = 1;
            }

            var vocabLines = [];
            for (var i = startIndex; i < lines.length; i++) {
                var line = lines[i].trim();
                if (!line) continue;
                var parts = parseCsvLine(line);
                if (parts.length >= 2) {
                    vocabLines.push(parts[0].trim() + ' = ' + parts[1].trim());
                }
            }

            if (vocabLines.length) {
                textarea.value = textarea.value
                    ? textarea.value + '\n' + vocabLines.join('\n')
                    : vocabLines.join('\n');
                textarea.dispatchEvent(new Event('change'));
            }
        };
        reader.readAsText(file);
    }

    async function handleOcrImport(input) {
        var files = input.files;
        if (!files.length) return;

        var status = document.getElementById('ocr-status');
        var textarea = document.getElementById('vocabulary-textarea');
        var btn = document.getElementById('ocr-btn');

        status.textContent = 'Scanne ' + files.length + ' Foto(s)...';
        status.className = 'help is-info';
        btn.classList.add('is-loading');

        var formData = new FormData();
        for (var i = 0; i < files.length; i++) {
            formData.append('files', files[i]);
        }

        try {
            var response = await fetch('/lists/ocr', { method: 'POST', body: formData });
            var data = await response.json();

            if (data.error) {
                status.textContent = data.error;
                status.className = 'help is-danger';
            } else if (data.text) {
                textarea.value = textarea.value
                    ? textarea.value + '\n' + data.text
                    : data.text;
                var lineCount = data.text.split('\n').filter(function(l) { return l.trim(); }).length;
                status.textContent = lineCount + ' Vokabeln aus Foto(s) erkannt.';
                status.className = 'help is-success';
            }
        } catch (e) {
            status.textContent = 'Fehler beim Scannen: ' + e.message;
            status.className = 'help is-danger';
        } finally {
            btn.classList.remove('is-loading');
            input.value = '';
        }
    }

    function parseCsvLine(line) {
        var result = [];
        var current = '';
        var inQuotes = false;
        for (var i = 0; i < line.length; i++) {
            var c = line[i];
            if (c === '"') {
                if (inQuotes && i + 1 < line.length && line[i + 1] === '"') {
                    current += '"';
                    i++;
                } else {
                    inQuotes = !inQuotes;
                }
            } else if (c === ',' && !inQuotes) {
                result.push(current);
                current = '';
            } else {
                current += c;
            }
        }
        result.push(current);
        return result;
    }
    </script>
</PageLayout>

@code {
    [Parameter] public int? Id { get; set; }
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public int SourceLanguageId { get; set; }
    [Parameter] public int TargetLanguageId { get; set; }
    [Parameter] public string RawVocabulary { get; set; } = "";
    [Parameter] public List<LanguageDto>? Languages { get; set; }
    [Parameter] public bool IsAdmin { get; set; }
    [Parameter] public bool OcrEnabled { get; set; }
}
