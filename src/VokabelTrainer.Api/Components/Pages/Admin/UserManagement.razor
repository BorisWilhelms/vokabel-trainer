@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@inject UserService UserService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager NavigationManager

<h1 class="title">Benutzerverwaltung</h1>

<div class="box">
    <h2 class="subtitle">Neuen Benutzer anlegen</h2>
    <form method="post" @formname="create-user" @onsubmit="HandleCreate">
        <AntiforgeryToken />
        <div class="field has-addons">
            <div class="control is-expanded">
                <input type="text" name="NewUsername" class="input" placeholder="Benutzername" value="@NewUsername" />
            </div>
            <div class="control">
                <button type="submit" class="button is-primary">Benutzer anlegen</button>
            </div>
        </div>
    </form>
</div>

@if (users is not null)
{
    <table class="table is-fullwidth is-striped">
        <thead>
            <tr>
                <th>Benutzername</th>
                <th>Rolle</th>
                <th>Status</th>
                <th>Aktionen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in users)
            {
                <tr>
                    <td>@user.Username</td>
                    <td>@user.Role</td>
                    <td>
                        @if (user.IsInitialized)
                        {
                            <span class="tag is-success">Initialisiert</span>
                        }
                        else
                        {
                            <span class="tag is-warning">Nicht initialisiert</span>
                        }
                    </td>
                    <td>
                        <div class="buttons are-small">
                            <form method="post" @formname="@($"reset-{user.Id}")" @onsubmit="HandleAction">
                                <AntiforgeryToken />
                                <input type="hidden" name="ActionUserId" value="@user.Id" />
                                <input type="hidden" name="Action" value="reset" />
                                <button type="submit" class="button is-small is-warning">Passwort zuruecksetzen</button>
                            </form>
                            <form method="post" @formname="@($"delete-{user.Id}")" @onsubmit="HandleAction">
                                <AntiforgeryToken />
                                <input type="hidden" name="ActionUserId" value="@user.Id" />
                                <input type="hidden" name="Action" value="delete" />
                                <button type="submit" class="button is-small is-danger" onclick="return confirm('Benutzer wirklich loeschen?')">Loeschen</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<UserDto>? users;

    [SupplyParameterFromForm(FormName = "create-user")]
    private string? NewUsername { get; set; }

    [SupplyParameterFromForm]
    private string? Action { get; set; }

    [SupplyParameterFromForm]
    private int? ActionUserId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        users = await UserService.GetAllAsync();
    }

    private async Task HandleCreate()
    {
        if (!string.IsNullOrWhiteSpace(NewUsername))
        {
            await UserService.CreateAsync(new CreateUserRequest(NewUsername));
        }
        NavigationManager.NavigateTo("/admin/users", forceLoad: true);
    }

    private async Task HandleAction()
    {
        if (ActionUserId is null || Action is null) return;

        switch (Action)
        {
            case "reset":
                await UserService.ResetPasswordAsync(ActionUserId.Value);
                break;
            case "delete":
                await UserService.DeleteAsync(ActionUserId.Value);
                break;
        }
        NavigationManager.NavigateTo("/admin/users", forceLoad: true);
    }
}
